<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Tema XML Pyloto — usado apenas por componentes legados Android
        (SplashScreen, notificações, system bars em XML).
        O tema Compose principal está em presentation/theme/Theme.kt.
    -->
    <style name="Theme.PylotoEntregador" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary — Azul Técnico -->
        <item name="colorPrimary">@color/tech_blue</item>
        <item name="colorOnPrimary">@color/background</item>
        <item name="colorPrimaryContainer">@color/tech_blue_dark</item>

        <!-- Secondary — Dourado -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/primary</item>
        <item name="colorSecondaryContainer">@color/gold_light</item>

        <!-- Tertiary — Verde Militar -->
        <item name="colorTertiary">@color/military_green</item>

        <!-- Background & Surface -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_dim</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Error -->
        <item name="colorError">@color/status_rejected</item>

        <!-- System bars -->
        <item name="android:statusBarColor">@color/tech_blue</item>
        <item name="android:navigationBarColor">@color/background</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.PylotoEntregador.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="postSplashScreenTheme">@style/Theme.PylotoEntregador</item>
    </style>
</resources>
